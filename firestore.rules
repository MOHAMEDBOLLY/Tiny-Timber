rules_version = '2';

// Tiny Timber MVP Firestore Security Rules
//
// Prior state (undocumented in this repo — rules were never managed via
// firebase.json/CLI here, only in the Firebase Console): confirmed by runtime
// testing on 2026-07-14 that the `products` collection allowed open read/write
// (Admin CRUD and Shop's realtime listener both worked with zero permission
// errors), while `orders` had no matching rule and every read/write returned
// FirebaseError permission-denied. No other collections are read from or
// written to by this app.
//
// This ruleset makes that explicit and adds the missing `orders` collection.
// `gallery` was added 2026-07-14 with the same MVP policy, approved explicitly
// by the project owner after its listener was confirmed to be permission-denied.
// `materials` was added 2026-07-14 for the new Materials CRUD module, same policy.
// `qrScans` was added 2026-07-14 for QR code scan analytics; documents contain
// only a timestamp/date/time, no personal or device data.
// MVP scope only: no auth exists yet, so all five collections are fully open.
// Do not broaden beyond these five collections without deliberate review.
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if true;
    }

    match /materials/{materialId} {
      allow read: if true;
      allow write: if true;
    }

    match /qrScans/{scanId} {
      allow read: if true;
      allow write: if true;
    }

    // Everything else stays denied (default-deny).
  }
}
